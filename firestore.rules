rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny rule
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) && isValidId(userId);
    }

    // Notifications subcollection
    match /users/{userId}/notifications/{notificationId} {
      allow read, write: if isOwner(userId) && isValidId(userId) && isValidId(notificationId);
    }

    // History subcollection
    match /users/{userId}/history/{historyId} {
      allow read, write: if isOwner(userId) && isValidId(userId) && isValidId(historyId);
    }

    // Global notifications
    match /global_notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if false; // System only
    }

    // Streaks collection (allow reading list/documents for Leaderboard, owner writes only)
    match /streaks/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) && isValidId(userId);
      allow delete: if false; // Streak data shouldn't be deleted by client
    }

    // Quiz leaderboard collection (allow reading list/documents for Leaderboard, owner writes only)
    match /quiz_leaderboard/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) && isValidId(userId);
      allow delete: if false;
    }

    // Groups collection
    match /groups/{groupId} {
      allow read: if isSignedIn() && (resource == null || resource.data.privacy == 'public' || resource.data.visibility == 'public' || isOwner(resource.data.ownerId) || request.auth.uid in resource.data.members || request.auth.uid in resource.data.admins);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isOwner(resource.data.ownerId) || 
        request.auth.uid in resource.data.admins || 
        ((resource.data.privacy == 'public' || resource.data.visibility == 'public') && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members', 'memberCount'])) // For joining public groups
      );
      allow delete: if isSignedIn() && isOwner(resource.data.ownerId);

      // Group Messages subcollection
      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/groups/$(groupId)).data.privacy == 'public' || 
          get(/databases/$(database)/documents/groups/$(groupId)).data.visibility == 'public' || 
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members ||
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.admins ||
          isOwner(get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId)
        );
        allow create: if isSignedIn() && (
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members ||
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.admins ||
          isOwner(get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId)
        );
      }
      
      // Group Invites subcollection
      match /invites/{inviteId} {
        allow read: if isSignedIn() && (
          isOwner(get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId) ||
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.admins ||
          resource.data.email == request.auth.token.email
        );
        allow create: if isSignedIn() && (
          isOwner(get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId) ||
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.admins
        );
        allow update, delete: if isSignedIn() && (
          isOwner(get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId) ||
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.admins ||
          resource.data.email == request.auth.token.email
        );
      }
    }
    
    // User Group Invites index
    match /user_invites/{inviteId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource == null || resource.data.email == request.auth.token.email || resource.data.invitedBy == request.auth.uid);
      allow update, delete: if isSignedIn() && (resource.data.email == request.auth.token.email || resource.data.invitedBy == request.auth.uid);
    }
  }
}
