rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Student Rules ---
    match /students/{studentId} {
      // Allow public retrieval of student info by ID (no auth required as it's a "retrieval" service)
      // or we can require auth if that's safer, but usually QR scanners use public URLs or IDs.
      // Let's allow public read for single documents to support the "Retreival" use case.
      allow get: if isValidId(studentId);
      
      // Prevent listing all students
      allow list: if false;

      // Prevent anyone from writing directly from the client for now
      allow create, update, delete: if false;
    }
  }
}
