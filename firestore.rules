rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid} (Firebase Auth UID)
    // Fields:
    //   - displayName: string (required, 1-100 chars)
    //   - phoneNumber: string (optional)
    //   - institution: string (optional)
    //   - grade: string (optional)
    //   - bio: string (optional)
    //   - photoURL: string (optional, URL)
    //   - learningGoal: string (optional)
    //   - learningStyle: string (Visual|Auditory|Reading/Writing|Kinesthetic)
    //   - credits: number (required, >= 0)
    //   - planType: string (Free|Starter|Scholar|Achiever)
    //   - phoneVerified: boolean (optional)
    //   - hasCompletedOnboarding: boolean (required)
    //   - createdAt: timestamp (immutable)
    //   - updatedAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "sjtutorai@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'credits', 'hasCompletedOnboarding']) &&
             data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 100 &&
             data.credits is number && data.credits >= 0 &&
             data.hasCompletedOnboarding is bool &&
             (!('learningStyle' in data) || data.learningStyle in ['Visual', 'Auditory', 'Reading/Writing', 'Kinesthetic']) &&
             (!('planType' in data) || data.planType in ['Free', 'Starter', 'Scholar', 'Achiever']) &&
             (!('photoURL' in data) || (data.photoURL is string && (data.photoURL.matches("^https://.*") || data.photoURL.matches("^data:image/.*"))));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      
      allow update: if (isOwner(userId) && isValidUser(request.resource.data)) || isAdmin();
      
      allow delete: if isAdmin();
    }
  }
}
