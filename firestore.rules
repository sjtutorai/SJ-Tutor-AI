rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny rule
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) && isValidId(userId);
    }

    // Notifications subcollection
    match /users/{userId}/notifications/{notificationId} {
      allow read, write: if isOwner(userId) && isValidId(userId) && isValidId(notificationId);
    }

    // History subcollection
    match /users/{userId}/history/{historyId} {
      allow read, write: if isOwner(userId) && isValidId(userId) && isValidId(historyId);
    }

    // Global notifications
    match /global_notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if false; // System only
    }

    // Streaks collection (allow reading list/documents for Leaderboard, owner writes only)
    match /streaks/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) && isValidId(userId);
      allow delete: if false; // Streak data shouldn't be deleted by client
    }

    // Shared content collection - zero-trust dynamic permissions
    match /sharedContent/{shareId} {
      allow read: if resource == null || resource.data.isPublic == true;
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid && isValidId(shareId);
      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid && isValidId(shareId);
      allow update: if isValidId(shareId) && (
        (isSignedIn() && resource.data.ownerUid == request.auth.uid) ||
        (resource.data.isPublic == true && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'likes', 'sharesCount', 'lastViewedAt']))
      );
    }
  }
}
