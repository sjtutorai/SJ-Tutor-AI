{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with academic settings and details",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "institution": { "type": "string" },
        "grade": { "type": "string" },
        "board": { "type": "string" },
        "bio": { "type": "string" },
        "photoURL": { "type": "string" },
        "learningGoal": { "type": "string" },
        "learningStyle": { "type": "string" },
        "credits": { "type": "number" },
        "planType": { "type": "string" },
        "claimedOffers": { "type": "array" }
      },
      "required": ["credits"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User specific push or pull notifications",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "category": { "type": "string" },
        "timestamp": { "type": "number" },
        "read": { "type": "boolean" },
        "targetUserId": { "type": "string" }
      },
      "required": ["title", "body", "timestamp", "read"]
    },
    "GlobalNotification": {
      "title": "GlobalNotification",
      "description": "Broadcast notifications for all users",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "category": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["title", "body", "timestamp"]
    },
    "Streak": {
      "title": "StreakData",
      "description": "Duolingo-style daily learning streak records",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "currentStreak": { "type": "number" },
        "highestStreak": { "type": "number" },
        "lastActivityDate": { "type": "string" },
        "streakHistory": { "type": "array" },
        "updatedAt": { "type": "number" }
      },
      "required": ["uid", "currentStreak", "highestStreak", "lastActivityDate", "streakHistory", "updatedAt"]
    },
    "Group": {
      "title": "Group",
      "description": "Cooperative student learning and discussion group",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "photoURL": { "type": "string" },
        "category": { "type": "string" },
        "ownerId": { "type": "string" },
        "ownerName": { "type": "string" },
        "ownerAvatar": { "type": "string" },
        "admins": { "type": "array" },
        "membersCount": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "name", "category", "ownerId", "ownerName", "createdAt", "updatedAt"]
    },
    "GroupMember": {
      "title": "GroupMember",
      "description": "A member belonging to a group",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string" },
        "joinedAt": { "type": "number" }
      },
      "required": ["userId", "displayName", "role", "joinedAt"]
    },
    "GroupJoinRequest": {
      "title": "GroupJoinRequest",
      "description": "A user's application to join a group",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "status": { "type": "string" },
        "requestedAt": { "type": "number" }
      },
      "required": ["userId", "displayName", "status", "requestedAt"]
    },
    "GroupMessage": {
      "title": "GroupMessage",
      "description": "A chat message, announcement, or material shared in a group",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderAvatar": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string" },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "senderId", "senderName", "text", "type", "timestamp"]
    },
    "Invitation": {
      "title": "Invitation",
      "description": "An invite link sent to a user email address for a study group",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "groupName": { "type": "string" },
        "groupDescription": { "type": "string" },
        "invitationMessage": { "type": "string" },
        "invitedByEmail": { "type": "string" },
        "invitedByName": { "type": "string" },
        "targetEmail": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "number" },
        "joinLink": { "type": "string" }
      },
      "required": ["id", "groupId", "groupName", "invitedByEmail", "invitedByName", "targetEmail", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores individual user profile and setting details"
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User specific notification records"
    },
    "/global_notifications/{notificationId}": {
      "schema": "GlobalNotification",
      "description": "System-wide broadcast alerts"
    },
    "/streaks/{userId}": {
      "schema": "Streak",
      "description": "Stores user daily sequence progress and stats"
    },
    "/groups/{groupId}": {
      "schema": "Group",
      "description": "Main group detail and configuration records"
    },
    "/groups/{groupId}/members/{userId}": {
      "schema": "GroupMember",
      "description": "Tracks active group membership"
    },
    "/groups/{groupId}/join_requests/{userId}": {
      "schema": "GroupJoinRequest",
      "description": "Pending, accepted, or rejected user request records"
    },
    "/groups/{groupId}/messages/{messageId}": {
      "schema": "GroupMessage",
      "description": "Discussion, announcement, and learning resource messages in a group"
    },
    "/invitations/{invitationId}": {
      "schema": "Invitation",
      "description": "Active group invitations sent to students"
    }
  }
}
