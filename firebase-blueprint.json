{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with academic settings and details",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "institution": { "type": "string" },
        "grade": { "type": "string" },
        "board": { "type": "string" },
        "bio": { "type": "string" },
        "photoURL": { "type": "string" },
        "learningGoal": { "type": "string" },
        "learningStyle": { "type": "string" },
        "credits": { "type": "number" },
        "planType": { "type": "string" },
        "claimedOffers": { "type": "array" }
      },
      "required": ["credits"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User specific push or pull notifications",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "category": { "type": "string" },
        "timestamp": { "type": "number" },
        "read": { "type": "boolean" },
        "targetUserId": { "type": "string" }
      },
      "required": ["title", "body", "timestamp", "read"]
    },
    "GlobalNotification": {
      "title": "GlobalNotification",
      "description": "Broadcast notifications for all users",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "category": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["title", "body", "timestamp"]
    },
    "Streak": {
      "title": "StreakData",
      "description": "Duolingo-style daily learning streak records",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "currentStreak": { "type": "number" },
        "highestStreak": { "type": "number" },
        "lastActivityDate": { "type": "string" },
        "streakHistory": { "type": "array" },
        "updatedAt": { "type": "number" }
      },
      "required": ["uid", "currentStreak", "highestStreak", "lastActivityDate", "streakHistory", "updatedAt"]
    },
    "History": {
      "title": "HistoryItem",
      "description": "User specific course learning activities, quizzes, summary history",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "timestamp": { "type": "number" },
        "content": { "type": "object" },
        "formData": { "type": "object" },
        "score": { "type": "number" }
      },
      "required": ["id", "type", "title", "timestamp"]
    },
    "SharedContent": {
      "title": "SharedContent",
      "description": "Public shared quiz, summary, notes, homework or tutor transcripts",
      "type": "object",
      "properties": {
        "shareId": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "object" },
        "ownerUid": { "type": "string" },
        "createdAt": { "type": "number" },
        "views": { "type": "number" },
        "likes": { "type": "number" },
        "isPublic": { "type": "boolean" },
        "sharesCount": { "type": "number" },
        "lastViewedAt": { "type": "number" }
      },
      "required": ["shareId", "type", "title", "content", "ownerUid", "createdAt", "views", "likes", "isPublic"]
    },
    "QuizLeaderboard": {
      "title": "QuizLeaderboard",
      "description": "User overall quiz points, high score, and rank summaries",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "totalScore": { "type": "number" },
        "quizzesCompleted": { "type": "number" },
        "highestScore": { "type": "number" },
        "lastActive": { "type": "number" }
      },
      "required": ["uid", "displayName", "totalScore", "quizzesCompleted", "highestScore", "lastActive"]
    },
    "Group": {
      "title": "Group",
      "description": "Study Group containing discussions and settings",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "privacy": { "type": "string", "enum": ["public", "private"] },
        "visibility": { "type": "string", "enum": ["public", "private"] },
        "category": { "type": "string" },
        "ownerId": { "type": "string" },
        "ownerName": { "type": "string" },
        "memberCount": { "type": "number" },
        "members": { "type": "array" },
        "admins": { "type": "array" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "privacy", "ownerId", "members", "isActive"]
    },
    "GroupMessage": {
      "title": "GroupMessage",
      "description": "Real-time message sent inside a Group chat",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "createdAt": { "type": "number" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string", "enum": ["image", "video", "document", "audio"] },
        "mediaName": { "type": "string" },
        "readBy": { "type": "array" },
        "clientMsgId": { "type": "string" }
      },
      "required": ["text", "senderId", "senderName"]
    },
    "UserGroupInvite": {
      "title": "UserGroupInvite",
      "description": "Group invitation record for a user",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "invitedBy": { "type": "string" },
        "invitedByName": { "type": "string" },
        "groupId": { "type": "string" },
        "groupName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined", "cancelled"] },
        "receiverUid": { "type": "string" },
        "createdAt": { "type": "number" },
        "expiresAt": { "type": "number" }
      },
      "required": ["email", "invitedBy", "groupId", "groupName", "status"]
    }
  },
  "firestore": {
    "/sharedContent/{shareId}": {
      "schema": "SharedContent",
      "description": "Public viewing records of shared materials"
    },
    "/quiz_leaderboard/{userId}": {
      "schema": "QuizLeaderboard",
      "description": "Leaderboard statistics for each user"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores individual user profile and setting details"
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User specific notification records"
    },
    "/users/{userId}/history/{historyId}": {
      "schema": "History",
      "description": "User specific generated course history, quizzes, and homework items"
    },
    "/global_notifications/{notificationId}": {
      "schema": "GlobalNotification",
      "description": "System-wide broadcast alerts"
    },
    "/streaks/{userId}": {
      "schema": "Streak",
      "description": "Stores user daily sequence progress and stats"
    },
    "/groups/{groupId}": {
      "schema": "Group",
      "description": "Collaborative Study Group details"
    },
    "/groups/{groupId}/messages/{messageId}": {
      "schema": "GroupMessage",
      "description": "Discussion messages within a group"
    },
    "/user_invites/{inviteId}": {
      "schema": "UserGroupInvite",
      "description": "Index of invitations sent to users"
    }
  }
}
