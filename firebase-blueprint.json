{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with academic settings and details",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "institution": { "type": "string" },
        "grade": { "type": "string" },
        "board": { "type": "string" },
        "bio": { "type": "string" },
        "photoURL": { "type": "string" },
        "learningGoal": { "type": "string" },
        "learningStyle": { "type": "string" },
        "credits": { "type": "number" },
        "planType": { "type": "string" },
        "claimedOffers": { "type": "array" }
      },
      "required": ["credits"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User specific push or pull notifications",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "category": { "type": "string" },
        "timestamp": { "type": "number" },
        "read": { "type": "boolean" },
        "targetUserId": { "type": "string" }
      },
      "required": ["title", "body", "timestamp", "read"]
    },
    "GlobalNotification": {
      "title": "GlobalNotification",
      "description": "Broadcast notifications for all users",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "body": { "type": "string" },
        "category": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["title", "body", "timestamp"]
    },
    "Streak": {
      "title": "StreakData",
      "description": "Duolingo-style daily learning streak records",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "currentStreak": { "type": "number" },
        "highestStreak": { "type": "number" },
        "lastActivityDate": { "type": "string" },
        "streakHistory": { "type": "array" },
        "updatedAt": { "type": "number" }
      },
      "required": ["uid", "currentStreak", "highestStreak", "lastActivityDate", "streakHistory", "updatedAt"]
    },
    "Group": {
      "title": "Group",
      "description": "A study cluster created or joined by users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "ownerId": { "type": "string" },
        "ownerName": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "memberCount": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "name", "ownerId", "isPublic", "createdAt"]
    },
    "GroupInvitation": {
      "title": "GroupInvitation",
      "description": "Invitations sent to other students to join a group",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "groupName": { "type": "string" },
        "inviteeId": { "type": "string" },
        "inviteeEmail": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"] },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "groupId", "groupName", "inviteeEmail", "senderId", "status", "createdAt"]
    },
    "GroupRequest": {
      "title": "GroupRequest",
      "description": "Join request submitted by students for private groups",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "groupName": { "type": "string" },
        "groupOwnerId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "groupId", "groupName", "groupOwnerId", "userId", "status", "createdAt"]
    },
    "GroupAnnouncement": {
      "title": "GroupAnnouncement",
      "description": "Official broadcast pin posted inside a details card",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "groupId", "title", "content", "authorId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores individual user profile and setting details"
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User specific notification records"
    },
    "/global_notifications/{notificationId}": {
      "schema": "GlobalNotification",
      "description": "System-wide broadcast alerts"
    },
    "/streaks/{userId}": {
      "schema": "Streak",
      "description": "Stores user daily sequence progress and stats"
    },
    "/groups/{groupId}": {
      "schema": "Group",
      "description": "Stores individual study group files"
    },
    "/groups/{groupId}/announcements/{announcementId}": {
      "schema": "GroupAnnouncement",
      "description": "Course-specific update details inside a specific group"
    },
    "/group_invitations/{invitationId}": {
      "schema": "GroupInvitation",
      "description": "Records representing user group invite objects"
    },
    "/group_requests/{requestId}": {
      "schema": "GroupRequest",
      "description": "Records representing pending membership join cases"
    }
  }
}
